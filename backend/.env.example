# Veritabanı - Docker Compose'taki postgres servisi
DB_HOST=localhost
DB_PORT=5432
DB_USER=app
DB_PASSWORD=secret
DB_NAME=periodically
DB_SSLMODE=disable

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# MinIO (S3-uyumlu)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=motivations
MINIO_USE_SSL=false

# JWT (güçlü bir secret üret: openssl rand -hex 32)
JWT_SECRET=your-super-secret-key-change-in-production

# OAuth — Apple: identity_token içindeki aud = iOS/macOS Bundle ID ile aynı olmalı (virgülle birden fazla)
APPLE_CLIENT_IDS=com.siyazilim.periodicallynotification
# Google Sign-In web client id (virgülle birden fazla)
# GOOGLE_OAUTH_CLIENT_IDS=

# Sunucu
PORT=8080

# Admin günlük gönderim: curl -H "X-Admin-Secret: ..." -X POST .../api/admin/daily-send
ADMIN_SECRET=

# iOS APNs (Apple Developer → Keys → APNs; AuthKey_xxx.p8)
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_TOPIC=com.siyazilim.periodicallynotification
# Prod: true (api.push.apple.com). Debug build için genelde false (sandbox).
APNS_PRODUCTION=false

# Opsiyonel: POST /api/auth/token (Firebase ID token) — kullanmıyorsanız boş bırakın
# FIREBASE_PROJECT_ID=
# FIREBASE_AUTH_CREDENTIALS_PATH=
